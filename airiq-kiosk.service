[Unit]
Description=AirIQ Kiosk Mode Display
After=airiq-server.service
Wants=airiq-server.service

[Service]
Type=simple
Environment="DISPLAY=:0"
Environment="XAUTHORITY=/home/airiq/.Xauthority"
ExecStart=/home/airiq/Desktop/finalProject/AirIQ/airiq-kiosk.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
